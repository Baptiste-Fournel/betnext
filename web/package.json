{
  "name": "@betnext/frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo front BetNext (npm workspaces) : deux apps Next.js (joueur, admin) partageant le contrat OpenAPI généré et des composants communs. Clients MINCES : zéro logique métier (elle reste back).",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "generate:api": "npm run generate --workspace @betnext/api-contract",
    "dev:player": "npm run dev --workspace @betnext/web-player",
    "dev:admin": "npm run dev --workspace @betnext/web-admin",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.2"
  }
}
