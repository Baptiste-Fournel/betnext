        "responses": {
          "200": {
            "description": "Cote courante (read-model) ou cote d'ouverture si aucun volume",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CurrentOddsDto"
                }
              }
