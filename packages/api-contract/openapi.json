  "info": {
    "title": "BetNext API",
    "description": "Contrat OpenAPI du back BetNext — source du client TYPÉ du front (généré, non écrit à la main).",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          },
          "service": {
            "type": "string",
            "example": "betnext"
          },
          "timestamp": {
            "type": "string",
            "example": "2026-06-16T00:00:00.000Z"
          }
        },
        "required": [
          "status",
          "service",
          "timestamp"
        ]
      },
      "CurrentOddsDto": {
        "type": "object",
        "properties": {
          "outcomeId": {
            "type": "string",
            "example": "lol-finale-a"
          },
          "odds": {
            "type": "number",
            "example": 2
          },
          "opening": {
            "type": "boolean",
            "example": true,
            "description": "true = cote d'ouverture (aucun volume encore), false = cote pilotée par le volume"
          }
        },
        "required": [
          "outcomeId",
          "odds",
          "opening"
        ]
      },
      "OddsLiveEventDto": {
        "type": "object",
        "properties": {
          "outcomeId": {
            "type": "string",
            "example": "lol-finale-a"
          },
          "odds": {
            "type": "number",
            "example": 2.35
          }
        },
        "required": [
          "outcomeId",
          "odds"
        ]
      },
      "PlaceBetRequest": {
        "type": "object",
        "properties": {
          "outcomeId": {
            "type": "string",
            "example": "lol-finale-a"
          },
          "stake": {
            "type": "number",
            "example": 20,
            "minimum": 0,
            "description": "Mise (strictement positive)"
          }
        },
        "required": [
          "outcomeId",
          "stake"
        ]
      },
      "PlaceBetResponse": {
        "type": "object",
        "properties": {
          "betId": {
            "type": "string",
            "example": "3f9c0b2e-..."
          },
          "lockedOdds": {
            "type": "number",
            "example": 2,
            "description": "Cote figée à la pose"
          },
          "potentialGain": {
            "type": "number",
            "example": 40
          },
          "pricingProvisional": {
            "type": "boolean",
            "example": true,
            "description": "Cote d'ouverture (read-model froid)"
          }
        },
        "required": [
          "betId",
          "lockedOdds",
          "potentialGain"
        ]
      },
      "BetViewDto": {
        "type": "object",
        "properties": {
          "betId": {
            "type": "string"
          },
          "userId": {
            "type": "string",
            "example": "demo-player"
          },
          "outcomeId": {
            "type": "string",
            "example": "lol-finale-a"
          },
          "stake": {
            "type": "number",
            "example": 20
          },
          "lockedOdds": {
            "type": "number",
            "example": 2
          },
          "potentialGain": {
            "type": "number",
            "example": 40
          },
          "status": {
            "type": "string",
            "example": "PENDING",
            "enum": [
              "PENDING",
              "WON",
              "LOST",
              "VOID",
              "COMPENSATING",
              "REFUNDED"
            ]
          }
        },
        "required": [
          "betId",
          "userId",
          "outcomeId",
          "stake",
          "lockedOdds",
          "potentialGain",
          "status"
        ]
      },
      "PlayerStatsDto": {
        "type": "object",
        "properties": {
          "totalBets": {
            "type": "number",
            "example": 12,
            "description": "Nombre total de paris du joueur"
          },
          "pending": {
            "type": "number",
            "example": 3,
            "description": "Paris en attente (indécis)"
          },
          "won": {
            "type": "number",
            "example": 5,
            "description": "Paris gagnés"
          },
          "lost": {
            "type": "number",
            "example": 3,
            "description": "Paris perdus"
          },
          "voided": {
            "type": "number",
            "example": 1,
            "description": "Paris annulés/remboursés"
          },
          "totalStaked": {
            "type": "number",
            "example": 240,
            "description": "Total misé (toutes mises confondues)"
          },
          "netResult": {
            "type": "number",
            "example": 35.5,
            "description": "Gains/pertes nets sur paris décidés"
          },
          "winRate": {
            "type": "number",
            "example": 0.625,
            "description": "Taux de réussite (gagnés / décidés), 0..1"
          }
        },
        "required": [
          "totalBets",
          "pending",
          "won",
          "lost",
          "voided",
          "totalStaked",
          "netResult",
          "winRate"
        ]
      },
      "BetEventDto": {
        "type": "object",
        "properties": {
          "seq": {
            "type": "number",
            "example": 1
          },
          "type": {
            "type": "string",
            "example": "BetPlaced",
            "enum": [
              "BetPlaced",
              "BetWon",
              "BetLost",
              "BetVoided"
            ]
          },
          "occurredAt": {
            "type": "string",
