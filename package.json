{
  "name": "betnext",
  "version": "0.1.0",
  "description": "POC d'architecture multi-jeux pour une plateforme de paris e-sport — monolithe modulaire NestJS, ready-to-split.",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:pricing": "node dist/pricing.main.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "boundaries": "depcruise src --config .dependency-cruiser.cjs",
    "test:naming": "node scripts/check-test-naming.cjs",
    "db:up": "docker compose up -d postgres",
    "migration:run": "typeorm migration:run -d dist/persistence/data-source.js",
    "migration:revert": "typeorm migration:revert -d dist/persistence/data-source.js",
    "test:atomicity:pg": "npm run build && node scripts/atomicity-pg.cjs",
    "test:reconciliation:pg": "npm run build && node scripts/reconciliation-pg.cjs",
    "test:bootstrap:pg": "npm run build && node scripts/bootstrap-pg.cjs",
    "db:seed": "npm run build && node scripts/seed.cjs",
    "test:outbox:redis": "npm run build && node scripts/outbox-redis.cjs",
    "test:pricing:redis": "npm run build && node scripts/pricing-redis.cjs",
    "test:readmodel:redis": "npm run build && node scripts/readmodel-redis.cjs",
    "openapi:generate": "npm run build && node scripts/generate-openapi.cjs",
    "api:types": "npm --prefix web run generate:api",
    "api:contract": "npm run openapi:generate && npm run api:types"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/cqrs": "^10.2.7",
    "@nestjs/microservices": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/swagger": "^8.1.1",
    "@nestjs/typeorm": "^10.0.2",
    "bullmq": "^5.78.1",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.30"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.22",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.10",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "dependency-cruiser": "^16.4.2",
    "embedded-postgres": "^18.4.0-beta.17",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "openapi-typescript": "^7.13.0",
    "pg-mem": "^3.0.14",
    "prettier": "^3.3.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.2"
  }
}
