# DATABASE_URL est REQUIS pour démarrer l'app (Postgres = store persistant par défaut, BET-19).
# Les migrations sont jouées au démarrage. Le mode en mémoire est réservé aux tests.
# `docker compose up -d postgres` fournit ce Postgres local ; puis `npm run db:seed`.
DATABASE_URL=postgres://betnext:betnext@localhost:5432/betnext
# Taille du pool de connexions Postgres (défaut 10).
DB_POOL_SIZE=10
PORT=3000
# File asynchrone (BullMQ). Vide = relais/consommateur inactifs (mode POC sans Redis).
REDIS_URL=redis://localhost:6379
# Secret de signature des tokens d'authentification (BET-20). REQUIS pour démarrer l'app.
# Générez une valeur aléatoire forte (ex. `openssl rand -hex 32`). NE PAS committer de vraie valeur.
AUTH_SECRET=dev-secret-change-me-please-use-openssl-rand-hex-32
# Feed LoL Esports (BET-30 ingestion + BET-32 résultats auto, API non-officielle). OPTIONNELLES :
# sans elles, ingestion ET résultats tournent sur des FIXTURES déterministes (LEC/LCK…, démo-able
# hors-ligne, avec un match « terminé » pour prouver le règlement auto). Avec elles : vrais matchs
# à venir (durci + bascule fixtures si KO) et vrais résultats (durci ; jamais de bascule fixtures
# côté résultats → on ne règle pas sur de fausses données). Clé PUBLIQUE (front lolesports.com)
# mais en ENV — jamais en dur ni loggée.
ESPORTS_API_BASE_URL=
ESPORTS_API_KEY=
# Rate-limit léger (ms) entre deux synchros de résultats (défaut 3000). 0 = pas de throttle.
ESPORTS_SYNC_MIN_INTERVAL_MS=
# Rafraîchissement AUTO du feed (BET-33), app « vivante » sans clic : un scheduler léger ré-ingère
# les matchs à venir + synchronise les résultats périodiquement. DÉSACTIVÉ par défaut → JAMAIS
# armé en test/CI ni sans opt-in (le scheduler ne doit pas taper l'API externe pendant les tests).
# Activez-le sur l'app qui tourne avec `true`/`1`/`yes`/`on`.
ESPORTS_SCHEDULER_ENABLED=
# Intervalle (ms) entre deux rafraîchissements auto (défaut 300000 = 5 min). Valeur ≤ 0 ou
# invalide → défaut. La synchro résultats garde en plus son propre rate-limit (ci-dessus).
ESPORTS_SCHEDULER_INTERVAL_MS=

# Paiement externe Stripe (BET-17, dépôt de fonds via saga). OPTIONNELLE : VIDE → PSP factice
# déterministe (StubPaymentGateway : démo + CI SANS clé, dépôt qui crédite directement le wallet).
# Renseignée avec une clé de TEST `sk_test_…` → adapter Stripe RÉEL (mode test) activé, durci par
# circuit breaker + timeout + retry. SECRÈTE : jamais en dur, jamais loggée, jamais committée.
STRIPE_SECRET_KEY=
# Clé PUBLIABLE Stripe (`pk_test_…`), exposée au front (publique PAR DESIGN — préfixe NEXT_PUBLIC_).
# Utile uniquement si l'on branche Stripe Elements (collecte de carte) ; non requise pour la démo
# stub. Ne jamais y mettre la clé secrète.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
